# Formspree — contact form email delivery
# 1. Create a free account at https://formspree.io
# 2. Create a new form and copy the ID from the endpoint URL
# 3. Rename this file to .env.local and paste your ID below
VITE_FORMSPREE_ID=your_form_id_here

# Google Analytics 4 — site analytics and ad conversion tracking
# Get your Measurement ID from https://analytics.google.com (looks like G-XXXXXXXXXX)
VITE_GA_ID=

# Meta Pixel — Facebook/Instagram ad retargeting
# Get your Pixel ID from https://business.facebook.com/events_manager (15-digit number)
VITE_META_PIXEL_ID=
